<?xml version="1.0" encoding="utf-8"?>
<!--
  Internal-loads (equipment/lighting/appliances) catalog (GC-COOLING-11):
  the reference templates offered by the Equipment step (laptop, monitor,
  server, ...). Loaded unconditionally (data, not demo) since these are
  real catalog entries the frontend fetches via GET /equipment-load-catalog
  instead of hardcoding them in a frontend source file.

  Reference values mirror the previous frontend-hardcoded array so this
  migration does not silently change what a new study proposes.
-->
<odoo noupdate="1">
    <record id="internal_load_laptop" model="product.template">
        <field name="name">Ordinateur portable</field>
        <field name="type">consu</field>
        <field name="sale_ok" eval="False"/>
        <field name="purchase_ok" eval="False"/>
        <field name="is_internal_load_equipment" eval="True"/>
        <field name="internal_load_code">laptop</field>
        <field name="internal_load_category">it</field>
        <field name="internal_load_unit_power_w">45</field>
        <field name="internal_load_usage_hours_per_day">8</field>
        <field name="internal_load_simultaneity_percent">100</field>
        <field name="data_quality">catalog</field>
    </record>

