<?xml version="1.0" encoding="utf-8"?>
<!--
  Canonical GreenCube model catalog (GC-COOLING-08): the standard,
  versioned thermal specifications a study can be based on. Loaded
  unconditionally (data, not demo) since these are real catalog entries,
  not throwaway sample data — the frontend's ModelStep fetches them via
  GET /thermal-specification-templates instead of hardcoding dimensions.
-->
<odoo noupdate="1">
    <record id="thermal_spec_catalog_studio" model="greencube.thermal.specification">
        <field name="name">GreenCube Studio</field>
        <field name="code">gc-studio</field>
        <field name="version">1.0</field>
        <field name="standard_model" eval="True"/>
        <field name="length_m">4.0</field>
        <field name="width_m">2.5</field>
        <field name="height_m">2.5</field>
        <field name="wall_u_value">0.18</field>
        <field name="roof_u_value">0.16</field>
        <field name="floor_u_value">0.20</field>
        <field name="airtightness_n50">0.6</field>
        <field name="thermal_mass_level">medium</field>
        <field name="thermal_bridge_factor">0.05</field>
        <field name="default_infiltration_ach">0.3</field>
        <field name="notes">Module compact idéal pour un espace de travail ou de vie individuel.</field>
    </record>
    <record id="thermal_spec_catalog_studio_south" model="greencube.thermal.facade">
        <field name="thermal_specification_id" ref="thermal_spec_catalog_studio"/>
        <field name="orientation">south</field>
        <field name="gross_area_m2">6.25</field>
        <field name="glazing_area_m2">4.0</field>
        <field name="window_u_value">1.3</field>
        <field name="solar_factor_g">0.5</field>
        <field name="visible_transmittance">0.7</field>
        <field name="default_shading_type">external_blind</field>
        <field name="default_shading_factor">0.6</field>
    </record>
    <record id="thermal_spec_catalog_studio_north" model="greencube.thermal.facade">
        <field name="thermal_specification_id" ref="thermal_spec_catalog_studio"/>
        <field name="orientation">north</field>
        <field name="gross_area_m2">6.25</field>
        <field name="glazing_area_m2">0</field>
    </record>
    <record id="thermal_spec_catalog_studio_east" model="greencube.thermal.facade">
        <field name="thermal_specification_id" ref="thermal_spec_catalog_studio"/>
        <field name="orientation">east</field>
        <field name="gross_area_m2">10.0</field>
        <field name="glazing_area_m2">1.0</field>
        <field name="window_u_value">1.3</field>
        <field name="solar_factor_g">0.5</field>
        <field name="visible_transmittance">0.7</field>
    </record>
    <record id="thermal_spec_catalog_studio_west" model="greencube.thermal.facade">
        <field name="thermal_specification_id" ref="thermal_spec_catalog_studio"/>
