    <!-- greencube.cooling.commercial.capacity had NO ir.rule at all: its
         company_id is not required (a False/global tier is valid), but a
         per-company tier (company_id set) was readable/writable by a
         Manager of ANY company with no boundary — found while reviewing
         multi-company behaviour for GC-COOLING-01 pt 6. Global rule so it
         also protects the read-only User ACL, not just the Manager. -->
    <record id="rule_commercial_capacity_company" model="ir.rule">
        <field name="name">GreenCube Commercial Capacity: multi-company or global tier</field>
        <field name="model_id" ref="model_greencube_cooling_commercial_capacity"/>
        <field name="domain_force">['|', ('company_id', '=', False), ('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[]"/>
    </record>

