        <field name="model_id" ref="model_greencube_cooling_solver_version"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="groups" eval="[(4, ref('group_greencube_cooling_user'))]"/>
    </record>

    <!-- GC-COOLING-18 audit finding: this rule used to be the *only* one
         for the model and was scoped to group_greencube_cooling_user
         instead of being global, so it acted purely as a per-group OR
         domain, not an AND'd boundary — and with no own_user rule beside
         it, any User-group member could read/write another user's
         equipment selection as long as it belonged to the same company
         (IDOR, same class of bug already fixed for equipment_load/
         ventilation_profile/occupancy_profile/calculation_snapshot above).
         Made global (groups=[]) so it is ANDed with everything, mirroring
         rule_cooling_study_company. -->
    <record id="rule_equipment_selection_company" model="ir.rule">
        <field name="name">GreenCube Cooling Equipment Selection: multi-company</field>
        <field name="model_id" ref="model_greencube_cooling_equipment_selection"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <!-- Explicit "clear all" (6, 0, []) rather than a bare `eval="[]"`:
             on module *upgrade* (not just fresh install) a many2many field
             with no commands leaves the previously-stored group untouched,
             so an already-installed database would keep this rule scoped
             to group_greencube_cooling_user instead of actually becoming
             global — caught by the upgrade test against gc_test_db. -->
        <field name="groups" eval="[(6, 0, [])]"/>
    </record>
    <record id="rule_equipment_selection_own_user" model="ir.rule">
        <field name="name">GreenCube Cooling Equipment Selection: user owns via study</field>
        <field name="model_id" ref="model_greencube_cooling_equipment_selection"/>
        <field name="domain_force">[('study_id.user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_greencube_cooling_user'))]"/>
