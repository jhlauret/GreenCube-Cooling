<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_cooling_study_list" model="ir.ui.view">
        <field name="name">greencube.cooling.study.list</field>
        <field name="model">greencube.cooling.study</field>
        <field name="arch" type="xml">
            <list>
                <field name="reference"/>
                <field name="name"/>
                <field name="partner_id"/>
                <field name="thermal_specification_id"/>
                <field name="state" widget="badge"/>
                <field name="revision_number"/>
                <field name="confidence_score" widget="percentage"/>
                <field name="user_id"/>
            </list>
        </field>
    </record>

    <record id="view_cooling_study_form" model="ir.ui.view">
        <field name="name">greencube.cooling.study.form</field>
        <field name="model">greencube.cooling.study</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_mark_ready" type="object" string="Vérifier la complétude" class="btn-secondary"/>
                    <button name="action_create_snapshot" type="object" string="Créer le snapshot" class="btn-secondary" invisible="state not in ('ready', 'incomplete')"/>
                    <button name="action_calculate" type="object" string="Calculer (MERCURE)" class="btn-primary" invisible="not input_snapshot_hash"/>
                    <button name="action_validate" type="object" string="Valider" class="btn-primary" invisible="state != 'calculated'"/>
                    <button name="action_create_revision" type="object" string="Créer une révision" invisible="state != 'validated'"/>
                    <field name="state" widget="statusbar" statusbar_visible="draft,incomplete,ready,calculating,calculated,validated"/>
                </header>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_results" type="object" class="oe_stat_button" icon="fa-bar-chart">
                            <field name="result_count" widget="statinfo" string="Résultats"/>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1><field name="reference" readonly="1"/></h1>
                        <field name="name"/>
                    </div>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="user_id"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="thermal_specification_id"/>
                            <field name="service_level"/>
                        </group>
                        <group>
                            <field name="parent_study_id" readonly="1"/>
                            <field name="root_study_id" readonly="1"/>
                            <field name="revision_number" readonly="1"/>
                            <field name="confidence_score" readonly="1" widget="percentage"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Localisation">
                            <group>
                                <field name="address"/>
                                <field name="city"/>
                                <field name="zip"/>
                                <field name="country_id"/>
                                <field name="latitude"/>
                                <field name="longitude"/>
                                <field name="altitude_m"/>
                                <field name="environment_type"/>
                                <field name="climate_confirmed"/>
                            </group>
                        </page>
                        <page string="Occupation">
                            <field name="occupancy_profile_ids">
                                <list editable="bottom">
                                    <field name="usage_type"/>
                                    <field name="usual_occupants"/>
                                    <field name="maximum_occupants"/>
                                    <field name="activity_level"/>
                                    <field name="start_hour"/>
                                    <field name="end_hour"/>
                                </list>
                            </field>
                        </page>
                        <page string="Équipements">
                            <field name="equipment_load_ids">
                                <list editable="bottom">
                                    <field name="name"/>
                                    <field name="category"/>
                                    <field name="quantity"/>
                                    <field name="unit_power_w"/>
                                    <field name="usage_hours_per_day"/>
                                    <field name="simultaneity_percent"/>
                                    <field name="thermal_load_w" readonly="1"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ventilation">
                            <field name="ventilation_profile_ids">
                                <list editable="bottom">
                                    <field name="ventilation_type"/>
                                    <field name="airflow_m3h"/>
                                    <field name="heat_recovery_efficiency_percent"/>
                                    <field name="infiltration_ach"/>
                                </list>
                            </field>
                        </page>
                        <page string="Ombrage">
                            <field name="shading_ids">
                                <list editable="bottom">
                                    <field name="orientation"/>
                                    <field name="shading_type"/>
                                    <field name="efficiency_percent"/>
                                </list>
                            </field>
                        </page>
                        <page string="Confort">
                            <group>
                                <field name="cooling_setpoint_c"/>
                                <field name="target_humidity_percent"/>
                            </group>
                        </page>
                        <page string="Résultats">
                            <field name="result_ids" readonly="1">
                                <list>
                                    <field name="create_date"/>
                                    <field name="governing_scenario_code"/>
                                    <field name="recommended_capacity_kw"/>
                                    <field name="shr"/>
                                    <field name="confidence_score" widget="percentage"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Audit">
                            <group>
                                <field name="calculation_date" readonly="1"/>
                                <field name="validation_date" readonly="1"/>
                                <field name="validator_id" readonly="1"/>
                                <field name="input_snapshot_hash" readonly="1"/>
                            </group>
                        </page>
                    </notebook>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <record id="action_cooling_study" model="ir.actions.act_window">
        <field name="name">Études</field>
        <field name="res_model">greencube.cooling.study</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo>
